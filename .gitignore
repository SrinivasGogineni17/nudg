# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
.env.production
.env.staging

# typescript
*.tsbuildinfo

# Documentation (only README.md is committed)
*.md
!README.md

# generated native folders
/ios
/android

# Kiro IDE cache (specs are tracked intentionally in .kiro/specs/)
.kiro/steering/
.kiro/settings/
